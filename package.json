{
	"name": "galileo",
	"private": true,
	"version": "1.0.1",
	"type": "module",
	"description": "Galileo is a test project for MERN/MEPN stack",
	"scripts": {
		"dev": "vite",
		"dev:server": "tsx --env-file=.env api/index.ts",
		"server": "tsx api/index.ts",
		"dev:all": "concurrently \"npm:dev\" \"npm:server\"",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"lint": "biome check .",
		"lint:fix": "biome check --fix --unsafe ."
	},
	"dependencies": {
		"cors": "^2.8.6",
		"express": "^5.1.0",
		"mongoose": "^9.5.0",
		"preact": "^10.27.2",
		"tsx": "^4.19.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.7",
		"@preact/preset-vite": "^2.10.2",
		"@tailwindcss/vite": "^4.1.17",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.2",
		"@types/node": "^25.6.0",
		"concurrently": "^9.1.2",
		"mongodb": "^7.2.0",
		"tailwindcss": "^4.1.17",
		"typescript": "^6.0.3",
		"vite": "^8.0.0"
	}
}
